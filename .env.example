# MQTT Configuration
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_TOPIC=factory/machine1/telemetry
MQTT_KEEPALIVE=60

# Anomaly Detection Thresholds
TEMP_THRESHOLD=80.0
VIBRATION_THRESHOLD=0.5

# Simulator Configuration
SIMULATOR_INTERVAL=5
SIMULATOR_RPM_MIN=900
SIMULATOR_RPM_MAX=1100
SIMULATOR_TEMP_MIN=70.0
SIMULATOR_TEMP_MAX=90.0
SIMULATOR_VIB_MIN=0.1
SIMULATOR_VIB_MAX=0.8

# API Configuration
API_HOST=127.0.0.1
API_PORT=8000

# Logging Configuration
LOG_LEVEL=INFO
